    /**
     * Shows the person overview inside the root layout.
     */
    public void showPersonOverview() {
        try {
            FXMLLoader loader = new FXMLLoader();
            java.net.URL url = MainApp.class.getResource("view/PersonOverview.fxml");
            System.out.println("URL PersonOverview: " + url);
            loader.setLocation(url);
            AnchorPane personOverview = (AnchorPane) loader.load();
            rootLayout.setCenter(personOverview);
            System.out.println("PersonOverview charge !"); // <-- ajoute ça
        } catch (Exception e) { // <-- change IOException en Exception
            System.out.println("ERREUR: " + e.getMessage());
            e.printStackTrace();
        }
    }
